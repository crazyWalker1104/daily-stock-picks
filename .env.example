# DeepSeek API 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 备选 Anthropic API（DeepSeek不可用时）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 邮箱配置（QQ邮箱 SMTP）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_qq_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code  # QQ邮箱需开启SMTP服务，用授权码
RECIPIENT_EMAIL=your_qq_email@qq.com

# 邮箱配置（163邮箱 SMTP — 二选一，覆盖上面QQ邮箱配置）
# SMTP_HOST=smtp.163.com
# SMTP_PORT=465                    # 163邮箱用SSL端口
# SMTP_USER=your_163_email@163.com
# SMTP_PASSWORD=your_163_authorization_code  # 163邮箱需开启SMTP服务，用授权码
# RECIPIENT_EMAIL=your_163_email@163.com

# 微信推送 — Server酱
# 1. 前往 https://sct.ftqq.com/ 登录获取 SendKey
# 2. 微信关注「方糖」公众号即可接收推送
WECHAT_SENDKEY=
