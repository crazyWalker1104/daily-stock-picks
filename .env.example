# DeepSeek API 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 备选 Anthropic API（DeepSeek不可用时）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 邮箱配置（QQ邮箱 SMTP）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_qq_email@qq.com
SMTP_PASSWORD=your_smtp_authorization_code  # QQ邮箱需开启SMTP服务，用授权码
RECIPIENT_EMAIL=your_qq_email@qq.com

# 微信推送（后续迭代，预留）
WECHAT_KEY=
